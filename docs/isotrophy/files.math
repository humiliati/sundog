(* ====================================================================
   sundog/docs/isotrophy/files.math
   --------------------------------------------------------------------
   Symbolic + numerical workbench for the Z_3 -> Z_2 descent check.
   See ../sundog_v_isotrophy.md for the framing.

   File format: Mathematica-flavored syntax, but every block is also
   readable as language-agnostic pseudocode. Python equivalents are
   noted inline where the numerical core will live (sympy + scipy +
   numpy in the eventual blowout).

   Conventions
     - Bodies indexed 1..3.
     - Positions x_i(t) in R^3. Velocities v_i(t) in R^3.
     - Period T. Phase t in [0, T).
     - Liao supplementary rows use a fixed symmetric ansatz, not full
       18D state rows. Expand the ansatz first, then optionally translate
       positions to the center-of-mass frame before integration/comparison.
     - Total linear momentum is zero by the velocity ansatz.
     - Raw scale has ||x_1(0) - x_2(0)|| = 2. Normalize only after ingestion
       if the detector needs dimensionless residuals.
   ==================================================================== *)


(* ======================================================
   Section A. Group-theoretic skeleton.
   ====================================================== *)

(* Body relabeling group at equal mass *)
S3 = { e, c12, c13, c23, c123, c132 };
(* in cycle notation:
   e    = ()
   c12  = (1 2)
   c13  = (1 3)
   c23  = (2 3)
   c123 = (1 2 3)
   c132 = (1 3 2)
*)

(* Surviving body-relabel stabilizer at m1 = m2 = 1, m3 = 1 + eps *)
Z2massbreak = { e, c12 };

(* Always-on dynamical symmetries (independent of mass perturbation) *)
S1time      = "phase shift t -> t + phi, phi in [0, T)";
TimeReverse = "t -> -t  (Hamiltonian symmetry of autonomous Newtonian dynamics)";
O3spatial   = "rigid rotation + reflection of R^3 (acts diagonally on all bodies)";

(* Full spacetime symmetry group *)
Gfull = S3 ** S1time ** TimeReverse ** O3spatial;

(* Surviving spacetime group after mass perturbation *)
Geps  = Z2massbreak ** S1time ** TimeReverse ** O3spatial;


(* ======================================================
   Section B. The four candidate residual Z_2 generators.
   ====================================================== *)

(* A generic element g of Geps acts on an orbit X(t) = {x_1, x_2, x_3}(t) by

      (g . X)(t) = R * P_perm * X( eps_t * (t - phi) )

   where
      P_perm  : permute body indices according to g.perm
      phi     : time shift
      eps_t   : +1 (forward) or -1 (time-reversed)
      R       : O(3) action on R^3, applied diagonally to all bodies
*)

(* The order-2 elements of Geps with body-relabel component (12),
   modulo conjugation by elements of the choreography's own Z_3: *)

alpha = << perm -> c12, tshift -> T/2, treverse -> False, zreflect -> False >>;
beta  = << perm -> c12, tshift -> 0,   treverse -> True,  zreflect -> False >>;
gamma = << perm -> c12, tshift -> T/2, treverse -> False, zreflect -> True  >>;
delta = << perm -> c12, tshift -> 0,   treverse -> True,  zreflect -> True  >>;

residualZ2candidates = { alpha, beta, gamma, delta };

(* Reading guide:
   alpha = Liao's piano-trio generator (forward time, T/2 shift, no reflection)
   beta  = isoscele time-reversal (body 1 forward == body 2 backward)
   gamma = chirally-flipped piano-trio (only nontrivial in 3D)
   delta = chirally-flipped time-reversal (only nontrivial in 3D)
*)


(* ======================================================
   Section B.5. The Li-Liao ansatz facet.
   ====================================================== *)

(* The verified supplementary format is already symmetry-conditioned:

      r1 = {-1, 0, 0}
      r2 = { 1, 0, 0}
      r3 = { 0, 0, z0}

      v1 = {vx, vy,  vz}
      v2 = {vx, vy, -vz}
      v3 = {-2 vx/m3, -2 vy/m3, 0}

   Let Rpi be the 180-degree rotation around the z-axis.
*)

Rpi = DiagonalMatrix[{-1, -1, 1}];

(* At t = 0:

      Rpi . r2 = r1
      Rpi . r1 = r2
      Rpi . r3 = r3

   and, with time reversal flipping velocities,

      -Rpi . v2 = v1
      -Rpi . v1 = v2
      -Rpi . v3 = v3

   Therefore the initial state is fixed by a beta-type generator

      facetBeta = ((12), time reversal, Rpi).

   By uniqueness of the Newtonian flow and m1=m2 equivariance, every orbit
   generated from this ansatz remains in the facet fixed by facetBeta.
*)

facetBeta = << perm -> c12, tshift -> 0, treverse -> True, spatial -> Rpi >>;

(* Consequence:

   The earlier unconditioned estimator

      K_raw = #{ i : S[i] != {} }

   is void for this catalog. Type-0 choreographies are outside the sampled
   template, not rare inside it. The corrected quantity is the
   facet-conditioned daughter multiplicity: count residual generators that
   are emergent relative to facetBeta, modulo sigma3 conjugation and spatial
   gauge equivalences.
*)


(* ======================================================
   Section C. Choreography isotropy Z_3.
   ====================================================== *)

sigma3 = << perm -> c123, tshift -> T/3, treverse -> False, zreflect -> False >>;

(* A choreography satisfies sigma3 . X = X. *)
choreographyConstraint[X_] := (sigma3 . X) === X;

(* For each choreography C_i (i = 1..21 at equal mass), the first test is:
   does C_i satisfy sigma3 in addition to the template-enforced facetBeta?

   Define
      S[i] := { rho in residualZ2candidates : isotropyHolds[C_i, rho] }
      E[i] := emergent residual generators in S[i] modulo <facetBeta>
      d[i] := facet-conditioned daughter multiplicity

   Retired theorem prediction (sundog v0.1, invalid under ansatz):
      # piano-trio families = #{ i : S[i] != {} }

   Corrected theorem prediction (sundog v0.2):
      # facet-visible piano-trio families = Sum_i d[i]
                                             = K_facet
*)


(* ======================================================
   Section D. Numerical isotropy detector.
   ====================================================== *)

(* Pseudocode -- to be implemented in Python (numpy + scipy.optimize). *)

isotropyResidual[orbit_, g_] := Module[{Xperm, Xshift, Xreflect, Xrotated},
   (* 1. Permute body labels according to g.perm *)
   Xperm = permuteBodies[orbit, g["perm"]];

   (* 2. Time shift: cyclic shift along the parameterization *)
   Xshift = cyclicTimeShift[Xperm, g["tshift"]];

   (* 3. Time reverse (if g.treverse) *)
   If[g["treverse"], Xshift = reverseTime[Xshift]];

   (* 4. z-reflection (if g.zreflect) *)
   If[g["zreflect"], Xshift = reflectZ[Xshift]];

   (* 5. Gauge: minimize over residual SO(3) and S^1 phase.
         Do not allow arbitrary improper O(3) here, or gamma/delta
         collapse into alpha/beta by gauge choice. Keep z-reflection
         as an explicit candidate operation. *)
   minimum[
     normInf[orbit - applyO3andPhase[Xshift, R, phi]] / scale[orbit],
     {R in SO(3), phi in [0, T)}
   ]
];

(* Mark g in Iso(orbit) iff isotropyResidual[orbit, g] < tolerance. *)

(* Implementation notes -- to be expanded:

   - Sampling: discretize X(t) on N points per period (start N = 1024).
   - Choose N coprime with the small denominators {2, 3} to avoid aliasing
     false positives for alpha (period-2) and sigma3 (period-3). N = 1009
     (prime) is convenient.
   - Gauge minimization:
       * SO(3) alignment: rotate so that the inertia tensor at t = 0 is
         diagonal with descending eigenvalues. Resolves continuous gauge.
       * Reflection diagnostic for gamma, delta: keep det(R) = +1 in the
         main classifier and apply reflectZ only through the candidate
         operator. A separate O(3)-collapsed residual may be reported as
         a gauge sanity check, but it must not decide chirality type.
       * Phase phi: anchor at argmin_t I_zz(t) (epoch of minimum moment of
         inertia about z-axis) to fix S^1.
   - Tolerance: relative, against orbit scale. Start at 1e-4; tighten to
     1e-6 once integration precision confirmed.
*)


(* ======================================================
   Section E. Data ingestion.
   ====================================================== *)

(* supplementary-A.txt and supplementary-B.txt:
   Verified live format from Numerical Tank:

     Orbit O_{index}(m_3)  z_0  v_x  v_y  v_z  T  stability

   Both files use the fixed initial-position ansatz

     r_1 = (-1, 0, 0)
     r_2 = ( 1, 0, 0)
     r_3 = ( 0, 0, z_0)

   supplementary-A uses m_1 = m_2 = 1 and

     v_1 = (v_x, v_y,  v_z)
     v_2 = (v_x, v_y, -v_z)
     v_3 = (-(m_1 + m_2) v_x / m_3,
            -(m_1 + m_2) v_y / m_3,
             0)

   supplementary-B is the piano-trio subset and writes the same relation as

     v_3 = (-2 v_x / m_3, -2 v_y / m_3, 0)

   Therefore the loader reconstructs masses, positions, velocities, period,
   and stability from compact rows. It must not expect full 18D state rows.
*)

suppA = "https://numericaltank.sjtu.edu.cn/three-body/three-body/gif/supplementary-A.txt";
suppB = "https://numericaltank.sjtu.edu.cn/three-body/three-body/gif/supplementary-B.txt";
github = "https://github.com/sjtu-liao/three-body";

(* Loader stubs (Python target):

     def load_supp(path: str) -> list[Orbit]:
         '''Parse Liao supplementary compact ansatz rows into Orbit records.
         Each Orbit has: source, index, m=(1,1,m3), x0, v0, T, stability.'''
         ...

     def integrate_orbit(orbit: Orbit, n_samples: int) -> Array[N, 3, 3]:
         '''High-precision integrator. Use scipy.integrate.solve_ivp with
         method='DOP853' and rtol=atol=1e-12 as a first pass; upgrade to
         mpmath-based fixed-step Verlet if residuals don't reach tolerance.'''
         ...
*)


