  "phase7eRecovery": {
    "boundary": "Toy micro-SEL box fragment only. This is not a general optimizer, not exact SEL inference, not a real-KG claim, and not an Ask Sundog product claim. It assumes the active-set trace is available; it does not prove that ordinary search will find that trace.",
    "closedFormPayload": {
      "a": "9/32",
      "b": "1/32",
      "float": 0.4100970508005519,
      "repr": "(9/32 + 1/32*sqrt17)"
    },
    "primaryRecoveryClaim": "For the Helly-seed n>=2 box fragment, an oracle-free active-set pressure trace recovers the lower endpoint by solving 4x^2 - 9x + 4 = 0 and returning 1/(4x); closed-form validation then confirms the recovered value is (9+sqrt17)/32.",
    "recoveredEndpointPayload": {
      "a": "9/32",
      "b": "1/32",
      "float": 0.4100970508005519,
      "repr": "(9/32 + 1/32*sqrt17)"
    },
    "recoveryRule": {
      "activeEquation": "4x^2 - 9x + 4 = 0",
      "endpointFormula": "1/(4x)",
      "feasibleRoot": "(9 - sqrt17)/8",
      "input": "active-set pressure trace",
      "usesClosedFormForRecovery": false,
      "usesClosedFormForValidation": true,
      "usesExactOracle": false
    },
    "recoveryVersion": "phase7e_oracle_free_recovery_v0",
    "status": "RECOVERY_RECEIPT",
    "traceInputOracleFree": true
  },
  "primaryReviewClaim": "On the locked tiny role-free micro-SEL fragment, restart-variance-only detection is structurally blind to stable false closure because it observes only seed_low_range; the stable PMP traps and pressure-noop controls share seed_low_range=0 while pressure-response traces separate the labels.",
