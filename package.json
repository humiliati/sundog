{
  "name": "sundog-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "postbuild": "node scripts/copy-site-docs.mjs && node scripts/check-site-dist.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "threebody:phase5": "node scripts/threebody-harness.mjs",
    "threebody:phase6": "node scripts/threebody-harness.mjs --phase phase6 --out results/threebody/phase6-baselines --modes off,naive,scan,seek,track,seek_noisy,track_noisy,seek_shuffled,track_shuffled,oracle --seeds 3",
    "threebody:phase7": "node scripts/threebody-harness.mjs --phase phase7 --out results/threebody/phase7-event-metrics --modes off,naive,scan,seek,track,seek_noisy,track_noisy,seek_shuffled,track_shuffled,oracle --seeds 3",
    "threebody:phase8": "node scripts/threebody-harness.mjs --phase phase8 --out results/threebody/phase8-sensor-model --modes off,naive,scan,seek,track,seek_sensor_accel,track_sensor_accel,seek_sensor_delayed,track_sensor_delayed,seek_sensor_micro,track_sensor_micro,oracle --seeds 3 --sensor-variants simulated_local_probe,accelerometer_array_noisy,delayed_local_probe,micro_maneuver_noisy",
    "threebody:phase8:calibrate": "node scripts/threebody-sensor-calibration-sweep.mjs",
    "deploy": "npm run build && node scripts/deploy-pages.mjs",
    "cf:auth": "node scripts/check-cloudflare-auth.mjs",
    "cf:inspect": "node scripts/inspect-cloudflare.mjs",
    "cf:pages": "node scripts/cloudflare-pages-project.mjs",
    "cf:tokens": "node scripts/create-cloudflare-scoped-tokens.mjs",
    "cf:domain": "node scripts/ensure-pages-domain.mjs"
  },
  "devDependencies": {
    "vite": "^8.0.10",
    "wrangler": "^4.87.0"
  }
}
